{
  "manifest_version": 3,
  "name": "CatHeadTab",
  "version": "1.0.0",
  "description": "A high-aesthetics, self-hostable new tab overriding extension with AI bookmarking.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "bookmarks",
    "history"
  ],
  "action": {
    "default_title": "CatHeadTab Settings"
  }
}
