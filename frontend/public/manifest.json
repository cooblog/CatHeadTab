{
  "manifest_version": 3,
  "name": "CatHeadTab",
  "version": "1.0.0",
  "description": "A high-aesthetics, self-hostable new tab overriding extension with AI bookmarking.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "bookmarks",
    "history",
    "favicon",
    "activeTab",
    "system.cpu",
    "system.memory",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://hq.sinajs.cn/*",
    "https://api.frankfurter.app/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "sina_headers",
        "enabled": true,
        "path": "rules/sina_headers.json"
      }
    ]
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "CatHeadTab – Add to Desktop",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
