{
  "manifest_version": 3,
  "name": "CatHeadTab - AI New Tab",
  "version": "1.0.0",
  "description": "A beautiful, customizable new tab with AI assistant, widgets, cloud sync and self-hosting support.",
  "homepage_url": "https://github.com/CatHeadTab/CatHeadTab",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "bookmarks",
    "history",
    "favicon",
    "activeTab",
    "system.cpu",
    "system.memory",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://hq.sinajs.cn/*",
    "https://api.frankfurter.app/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*",
    "https://open.bigmodel.cn/*",
    "https://api.moonshot.cn/*",
    "https://api.minimax.chat/*",
    "https://dashscope.aliyuncs.com/*",
    "https://github.com/*",
    "https://api.bilibili.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "sina_headers",
        "enabled": true,
        "path": "rules/sina_headers.json"
      }
    ]
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "CatHeadTab – Add to Desktop",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
