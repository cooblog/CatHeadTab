{
  "manifest_version": 3,
  "name": "CatHeadTab",
  "version": "1.0.0",
  "description": "A high-aesthetics, self-hostable new tab overriding extension with AI bookmarking.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "bookmarks",
    "history",
    "system.cpu",
    "system.memory"
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "CatHeadTab Settings",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
