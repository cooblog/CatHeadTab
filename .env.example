# CatHeadTab Environment Variables
# Copy this file to .env and fill in your values.
# All variables below have defaults in docker-compose.yml — only override what you need.

# ============================================================
# PostgreSQL (used by docker-compose for the DB container)
# ============================================================
POSTGRES_USER=catheadtab
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=catheadtab
POSTGRES_PORT=5432

# ============================================================
# Core Backend
# ============================================================
# Database connection string (for local dev without Docker).
# When using docker-compose, DB_DSN is auto-generated from POSTGRES_* vars above.
DB_DSN=postgres://catheadtab:secretpassword@localhost:5432/catheadtab?sslmode=disable

# JWT signing secret — CHANGE THIS in production!
JWT_SECRET=dev-secret-change-me

# Server listen port
PORT=8080

# Gin framework mode: debug / release / test
GIN_MODE=debug

# Frontend URL (used in email links: verification, password reset)
# When using docker-compose, defaults to http://localhost:${FRONTEND_PORT}
FRONTEND_URL=http://localhost:80

# Backend URL (externally accessible address of this backend server)
# Used as OAuth redirect_uri so GitHub/Google always callback to the backend.
# Must be reachable from the public internet for OAuth to work.
# Examples: https://api.catheadtab.com, http://your-server-ip:8080
BACKEND_URL=http://localhost:8080

# ============================================================
# Frontend (Nginx)
# ============================================================
# Host port for the frontend web UI
FRONTEND_PORT=80

# Backend API URL injected at build time (Vite).
# When set, the frontend will use this URL directly and the
# "Server URL" input in Settings / Auth will be hidden.
# Leave empty to let users configure the backend URL manually.
VITE_API_URL=

# Umami Analytics 埋点配置 (可选)
# 配置 WEBSITE_ID 会在部署时向页面自动注入 `<script data-website-id="...">`
VITE_UMAMI_WEBSITE_ID=
# 若是自建的 Umami，可填写自定义上报地址 (默认: https://analytics.umami.is/script.js)
VITE_UMAMI_SRC=

# ============================================================
# SMTP Email (optional, for email verification & password reset)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@catheadtab.com
# Use implicit SSL (port 465/994): true; STARTTLS (port 587): false or empty
#SMTP_SSL=true

# ============================================================
# GitHub OAuth (optional, for SSO login)
# Create at: https://github.com/settings/developers
# ============================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================
# Google OAuth (optional, for SSO login)
# Create at: https://console.cloud.google.com/apis/credentials
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Wallpaper Source: Wallhaven (optional)
# Get your API key at: https://wallhaven.cc/settings/account
# Without a key the provider still works (SFW only);
# with a key you also get Sketchy content filtering.
# ============================================================
WALLHAVEN_API_KEY=
#WALLHAVEN_PURITY=sfw,sketchy,nsfw

# ============================================================
# Wallpaper Source: Tencent Cloud COS (optional)
# When all four fields are set, COS becomes an available
# wallpaper source in the frontend (☁️ 云端壁纸库).
# Create keys at: https://console.cloud.tencent.com/cam/capi
# ============================================================
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=your-bucket-1234567890
COS_REGION=ap-guangzhou
# COS directory prefixes for wallpapers.
# Original (full-size) images and thumbnails are stored in separate directories
# with matching filenames. Example structure:
#   0000-c/sunset.jpg   (original)
#   0000-s/sunset.jpg   (thumbnail)
COS_ORIGINAL_PREFIX=0000-c/
COS_THUMB_PREFIX=0000-s/

# ============================================================
# Token TTL (optional)
# ============================================================
# Email verification token TTL (hours), default: 24
#EMAIL_VERIFY_TOKEN_TTL_HOURS=24
# Password reset token TTL (minutes), default: 5
#PASSWORD_RESET_TOKEN_TTL_MINUTES=5
# JWT login token TTL (days), default: 30
#JWT_TOKEN_TTL_DAYS=30
# Expired token cleanup interval (hours), default: 6
#TOKEN_CLEANUP_INTERVAL_HOURS=6

# ============================================================
# Logging (optional)
# ============================================================
# Minimum log level: debug / info / warn / error
LOG_LEVEL=info
# Log file path (inside container: /app/logs/app.log; mapped to ./data/logs/ on host)
# Leave empty to log to console only.
#LOG_FILE=/app/logs/app.log
# Max size of a single log file in MB before rotation
LOG_MAX_SIZE_MB=100
# Max days to retain old log files
LOG_MAX_AGE_DAYS=30
# Max number of old log files to keep
LOG_MAX_BACKUPS=10
# Gzip compress rotated log files: true / false
LOG_COMPRESS=false

# ============================================================
# Server-side AI (optional)
# When configured, Pro/Admin users can use AI features without their own API Key.
# Supports any OpenAI-compatible API (OpenAI, DeepSeek, GLM, Kimi, etc.)
# ============================================================
# Provider label (informational only, shown in frontend)
#AI_PROVIDER=openai
# OpenAI-compatible API base URL
#AI_BASE_URL=https://api.openai.com/v1
# API Key for the provider
#AI_API_KEY=sk-xxx
# Model identifier
#AI_MODEL=gpt-4o-mini
# Max requests per minute per user (default: 20)
#AI_RATE_LIMIT_RPM=20
# Max total tokens per user per day, 0 = unlimited (default: 100000)
#AI_DAILY_TOKEN_LIMIT=100000
