# CatHeadTab Environment Variables
# Copy this file to .env and fill in your values.
# All variables below have defaults in docker-compose.yml — only override what you need.

# ============================================================
# PostgreSQL (used by docker-compose for the DB container)
# ============================================================
POSTGRES_USER=catheadtab
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=catheadtab
POSTGRES_PORT=5432

# ============================================================
# Core Backend
# ============================================================
# Database connection string (for local dev without Docker).
# When using docker-compose, DB_DSN is auto-generated from POSTGRES_* vars above.
DB_DSN=postgres://catheadtab:secretpassword@localhost:5432/catheadtab?sslmode=disable

# JWT signing secret — CHANGE THIS in production!
JWT_SECRET=dev-secret-change-me

# Server listen port
PORT=8080

# Gin framework mode: debug / release / test
GIN_MODE=debug

# Frontend URL (used in email links: verification, password reset)
# When using docker-compose, defaults to http://localhost:${FRONTEND_PORT}
FRONTEND_URL=http://localhost:80

# ============================================================
# Frontend (Nginx)
# ============================================================
# Host port for the frontend web UI
FRONTEND_PORT=80

# ============================================================
# SMTP Email (optional, for email verification & password reset)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@catheadtab.com

# ============================================================
# GitHub OAuth (optional, for SSO login)
# Create at: https://github.com/settings/developers
# ============================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================
# Google OAuth (optional, for SSO login)
# Create at: https://console.cloud.google.com/apis/credentials
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Wallpaper Source: Wallhaven (optional)
# Get your API key at: https://wallhaven.cc/settings/account
# Without a key the provider still works (SFW only);
# with a key you also get Sketchy content filtering.
# ============================================================
WALLHAVEN_API_KEY=
